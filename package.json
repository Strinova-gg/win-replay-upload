{
  "name": "win-replay-upload",
  "version": "0.1.0",
  "description": "Strinova replay uploader (Electrobun + React + Clerk)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electrobun dev",
    "dev:watch": "electrobun dev --watch",
