    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  },
  "trustedDependencies": [
    "@clerk/shared"
  ]
}
