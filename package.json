{
  "name": "win-replay-upload",
  "version": "0.1.0",
  "description": "Stringify Desktop (Electrobun + React + Clerk OAuth)",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "bun run scripts/patch-electrobun-rcedit.ts",
    "dev": "bun run scripts/patch-electrobun-rcedit.ts && electrobun dev",
    "dev:watch": "bun run scripts/patch-electrobun-rcedit.ts && electrobun dev --watch",
    "build": "bun run scripts/patch-electrobun-rcedit.ts && electrobun build && bun run scripts/stamp-win-icon.ts",
    "package": "bun run scripts/patch-electrobun-rcedit.ts && electrobun build --env=stable && bun run scripts/stamp-win-icon.ts",
    "patch:electrobun": "bun run scripts/patch-electrobun-rcedit.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "electrobun": "^1.16.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  }
}
